baseURL = 'https://jpcorps.github.io/'
defaultContentLanguage = 'ko'
title = '대충 살아가는 게임개발자'
theme = "blowfish"

# 1. 사이트 전체 파라미터
[params]
  colorScheme = "fire"           # 디자인의 핵심! fire, emerald, ocean, terminal 중 골라보세요.
  defaultAppearance = "dark"     # 기본 모드를 다크모드로 고정 (개발자 국룰)
  mainSections = ["posts"]       # 메인에 posts 폴더 글들을 보여줌

# 2. 홈페이지(첫 화면) 레이아웃 설정
[params.homepage]
  layout = "background"          # "card"보다 훨씬 시원시원한 레이아웃입니다.
  showRecent = true              # 최근 글 보여주기
  showRecentItems = 10           # 글 갯수
  showMoreLink = true            # '더 보기' 버튼 활성화

# 3. 글 읽는 화면(본문) 설정
[params.article]
  showDate = true                # 날짜 표시
  showReadingTime = true         # 읽는 데 걸리는 시간 표시
  showTableOfContents = true     # 오른쪽에 목차(TOC) 띄우기

# 4. 마크다운 렌더링 설정 (기존에 넣었던 HTML 허용 설정)
[markup]
  [markup.goldmark]
    [markup.goldmark.renderer]
      unsafe = true